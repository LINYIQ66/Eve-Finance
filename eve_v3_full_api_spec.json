    "409": {"code": "ORDER_NOT_MODIFIABLE", "message": "Final or upstream-locked order"},
    "422": {"code": "INVALID_LOT_SIZE", "message": "Quantity violates asset lot rule"},
    "422": {"code": "INSUFFICIENT_BUYING_POWER", "message": "Available funds below required amount"},
    "422": {"code": "FX_QUOTE_EXPIRED", "message": "Request a new executable quote"},
    "423": {"code": "ACCOUNT_RESTRICTED", "message": "Risk/compliance hold"},
    "429": {"code": "RATE_LIMITED", "message": "Retry after Retry-After header"},
    "502": {"code": "UPSTREAM_UNAVAILABLE", "message": "Retryable broker/bank dependency failure"}
  },
