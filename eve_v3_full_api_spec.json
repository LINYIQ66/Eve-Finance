        "action": "subscribe",
        "channels": ["orders:acc_01JZ8", "positions:acc_01JZ8", "quotes:AAPL,0700.HK"]
      },
      "message_example": {
        "channel": "orders:acc_01JZ8",
        "sequence": 9182,
        "event": "order.filled",
        "data": {"order_id": "ord_...", "filled_qty": "100"}
      }
    }
  ],
  "webhook_events": [
    "order.accepted", "order.rejected",
    "order.partially_filled", "order.filled",
    "order.cancelled",
    "deposit.detected", "deposit.posted", "deposit.reversed",
