            {"currency": "HKD", "total": "245000.00", "settled": "245000.00", "available": "225000.00", "withdrawable": "220000.00"}
          ],
          "valuation_fx_time": "2026-07-10T03:31:02Z"
        }
      }
    },
    {
      "method": "GET",
      "path": "/v3/accounts/{account_id}/ledger",
      "group": "Accounts",
      "summary": "Cash ledger — immutable double-entry journal",
      "auth": "Bearer",
      "params": {
        "account_id": "path",
        "currency": "query — filter by currency",
        "from_date": "query — ISO date",
        "to_date": "query — ISO date",
        "limit": "query — integer (default 100)",
        "cursor": "query — pagination cursor"
      },
      "response_example": {
        "data": [{
          "entry_id": "le_01JZA31D",
          "transaction_id": "ltx_01JZA31",
          "account_id": "acc_01JZ8",
          "currency": "USD",
          "direction": "debit",
          "amount": "10000.00",
          "entry_type": "fx_conversion_principal",
          "reference_type": "fx_conversion",
          "reference_id": "fxc_01JZA3",
          "posted_at": "2026-07-10T03:40:18.008Z",
          "value_date": "2026-07-10",
          "running_balance": "60000.00"
        }]
      }
    },
    {
      "method": "GET",
      "path": "/v3/positions",
      "group": "Trading",
