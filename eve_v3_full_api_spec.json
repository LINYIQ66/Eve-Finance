      "X-EVE-Timestamp": "1783655400",
      "X-EVE-Signature": "v1=4b0e..."
    },
    "verification": "HMAC_SHA256(webhook_secret, timestamp + '.' + raw_body)",
    "replay_protection": "Reject when timestamp drift > 300 seconds"
