{
  "name": "EVE FINANCE — White-Label Trading API v3.0",
  "version": "3.0",
  "updated": "2026-07-10",
  "base_url": "https://sub.readinghero.xyz/eve-finance",
  "api_prefix": "/v3",
  "protocols": ["HTTPS REST", "WebSocket"],
  "markets": ["US equities", "HK equities", "FX cash conversion"],
  "auth_mode": "Anonymous (no key needed) or OAuth2 client_credentials",
  "environments": {
    "sandbox": "https://sandbox-api.evefinance.example/v3",
    "uat": "https://uat-api.evefinance.example/v3",
    "production": "https://sub.readinghero.xyz/eve-finance/v3"
  },
  "standard_headers": {
    "Authorization": "Bearer <access_token> (required for protected endpoints)",
    "X-API-Key": "ev_live_... (service integrations)",
    "Content-Type": "application/json",
    "Idempotency-Key": "UUID unique for ≥24 hours (all financial writes)",
    "X-Request-ID": "Caller correlation ID (recommended)",
    "X-Tenant-ID": "Tenant UUID (platform/admin only)",
    "X-EVE-Version": "2026-07-10 (optional)"
  },
  "scopes": {
    "market:read": "Asset search, quotes, bars, clocks and FX indicative rates",
    "accounts:read": "Account profiles, balances, positions and statements",
    "orders:write": "Preview, submit, replace and cancel orders",
    "fx:write": "Create executable FX quotes and currency conversions",
    "funding:write": "Create deposit/withdrawal instructions; no approval",
    "admin:funding:approve": "Approve/reject funding operations",
    "admin:ledger:adjust": "Create controlled adjustment journal",
    "admin:clients:write": "Suspend clients, change limits and permissions",
    "audit:read": "Read immutable audit events and reconciliation reports"
  },
  "rate_limits": {
    "market_snapshots": "60 req/min/key; batch up to 100 symbols",
    "order_writes": "30 req/sec/account with burst controls",
    "funding_writes": "10 req/min/client",
    "admin_search": "120 req/min/admin",
    "webhook_delivery": "Exponential retry for 24 hours; dead-letter queue after"
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/v3/oauth/token",
      "group": "Authentication",
      "summary": "Issue access token",
      "auth": "Basic (client_id:client_secret)",
      "content_type": "application/x-www-form-urlencoded",
      "params": {
        "grant_type": "client_credentials",
        "scope": "accounts:read orders:write funding:read"
      },
      "response": {
        "access_token": "eyJhbGciOi...",
        "token_type": "Bearer",
        "expires_in": 900,
        "scope": "accounts:read orders:write funding:read"
      }
    },
    {
      "method": "GET",
      "path": "/v3/health",
      "group": "System",
      "summary": "Health check",
      "auth": "none",
      "response": {
        "status": "ok",
        "version": "3.0"
      }
    },
    {
      "method": "GET",
      "path": "/v3/assets",
      "group": "Market Data",
      "summary": "Search asset master",
      "auth": "Bearer",
      "params": {
        "query": "string — search term (e.g. '0700')",
        "market": "string — US, HK",
        "status": "string — active, inactive"
      },
      "response_example": {
        "data": [{
          "asset_id": "ast_hk_00700",
          "symbol": "0700.HK",
          "name": "Tencent Holdings Ltd",
          "asset_class": "equity",
          "exchange": "SEHK",
          "currency": "HKD",
          "lot_size": 100,
          "odd_lot_supported": false,
          "tick_size_rule_id": "HKEX_EQ_2026",
          "shortable": false,
          "fractionable": false,
          "trade_status": "tradable"
        }]
      }
    },
    {
      "method": "GET",
      "path": "/v3/market/quotes",
      "group": "Market Data",
      "summary": "Quote snapshot",
      "auth": "Bearer",
      "params": {
        "symbols": "string — comma-separated (e.g. 'AAPL,0700.HK')",
        "fields": "string — last,bid,ask,bid_size,ask_size,lot_size"
      },
      "response_example": {
        "data": [
          {"symbol": "AAPL", "currency": "USD", "last": "222.18", "bid": "222.16", "ask": "222.20", "bid_size": "400", "ask_size": "300", "delayed": false, "as_of": "2026-07-10T03:32:01.245Z"},
          {"symbol": "0700.HK", "currency": "HKD", "last": "512.50", "bid": "512.00", "ask": "512.50", "bid_size": "1200", "ask_size": "800", "lot_size": 100, "delayed": false, "as_of": "2026-07-10T03:32:01.100Z"}
        ]
      }
    },
    {
      "method": "GET",
      "path": "/v3/market/bars",
      "group": "Market Data",
      "summary": "Historical bars",
      "auth": "Bearer",
      "params": {
        "symbol": "string — e.g. 'AAPL'",
        "timeframe": "string — 1Min, 5Min, 15Min, 1Hour, 1Day",
        "limit": "integer — number of bars",
        "start": "date — ISO 8601",
        "end": "date — ISO 8601"
      }
    },
    {
      "method": "GET",
      "path": "/v3/market/klines",
      "group": "Market Data",
      "summary": "Candlestick data",
      "auth": "Bearer",
      "params": {
        "symbol": "string",
        "timeframe": "string — 1d, 5d, 1m, etc.",
        "limit": "integer"
      }
    },
    {
      "method": "GET",
      "path": "/v3/market/snapshots",
      "group": "Market Data",
      "summary": "Market snapshots",
      "auth": "Bearer",
      "params": {
        "symbols": "string — comma-separated"
      }
    },
    {
      "method": "GET",
      "path": "/v3/market/clock",
      "group": "Market Data",
      "summary": "Market clock (US + HK status)",
      "auth": "Bearer"
    },
    {
      "method": "GET",
      "path": "/v3/accounts",
      "group": "Accounts",
      "summary": "List accounts",
      "auth": "Bearer"
    },
    {
      "method": "GET",
      "path": "/v3/accounts/{account_id}/summary",
      "group": "Accounts",
      "summary": "Account summary — NAV, balances, buying power",
      "auth": "Bearer",
      "params": {
        "account_id": "path — account ID",
        "base_currency": "query — valuation currency (e.g. 'SGD')"
      },
      "response_example": {
        "data": {
          "account_id": "acc_01JZ8",
          "base_currency": "SGD",
